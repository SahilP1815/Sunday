# =============================================
#  Sunday AI Backend — Environment Variables
# =============================================

# --- REQUIRED ---
# Your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- OPTIONAL ---
# GNews API key — free tier at https://gnews.io (required for /api/news)
GNEWS_API_KEY=

# SerpAPI key — https://serpapi.com (100 free searches/month)
# Without this, the search endpoint falls back to DuckDuckGo Instant Answers
SERPAPI_KEY=

# Tavily API key — https://tavily.com (for AI-optimized web searches)
TAVILY_API_KEY=

# Sarvam AI API Key (for speech-to-text and text-to-speech)
SARVAM_API_KEY=

# Server port (default: 3001)
PORT=3001

# CORS allowed origin — set to your frontend URL in production
# Use * to allow all origins (fine for local dev)
FRONTEND_URL=*
